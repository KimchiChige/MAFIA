<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:tools="http://schemas.android.com/tools" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_gradient" tools:context=".LobbyActivity">
    <!--  Верхняя панель с информацией о пользователе  -->
    <LinearLayout android:id="@+id/topBar" android:layout_width="0dp" android:layout_height="wrap_content" android:orientation="horizontal" android:background="@color/black" android:padding="16dp" android:gravity="center_vertical" android:elevation="8dp" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent">
        <!--  Аватар (кликабельный, открывает профиль)  -->
        <ImageView android:id="@+id/userAvatarImage" android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_player_avatar1" android:background="@drawable/circle_avatar_background" android:padding="4dp" android:scaleType="centerCrop" android:layout_marginEnd="12dp" android:clickable="true" android:focusable="true"/>
        <!--  Имя и статистика  -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <TextView android:id="@+id/nicknameText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="18sp" android:textColor="#FFFFFF" android:textStyle="bold" android:fontFamily="sans-serif-condensed" android:letterSpacing="0.05"/>
            <TextView android:id="@+id/userStatsText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Побед: 0 | Игр: 0" android:textSize="13sp" android:textColor="#C0C0C0" android:layout_marginTop="2dp" android:fontFamily="sans-serif-light"/>
        </LinearLayout>
        <!--  Кнопка профиля убрана — для открытия профиля нажмите на аватар  -->
    </LinearLayout>
    <!--  Кнопка выхода  -->
    <TextView android:id="@+id/logoutButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Выйти" android:gravity="left" android:layout_marginTop="5dp" android:textSize="18sp" android:textColor="#450000" android:elevation="10dp" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="parent" android:layout_margin="20dp"/>
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout android:id="@+id/swipeRefreshLayout" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintTop_toBottomOf="@id/topBar" app:layout_constraintBottom_toTopOf="@id/bottomPanel" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">
        <!--  Основной контент  -->
        <LinearLayout android:id="@+id/mainContent" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="24dp">
            <!--  Заголовок  -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="АКТИВНЫЕ СТОЛЫ" android:textSize="22sp" android:textColor="#FFFFFF" android:textStyle="bold" android:fontFamily="sans-serif-condensed" android:letterSpacing="0.1" android:layout_marginBottom="20dp" android:shadowColor="#8B0000" android:shadowRadius="2" android:shadowDx="1" android:shadowDy="1"/>
            <!--  Карточка для списка комнат  -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" app:cardBackgroundColor="#1A1A1A" app:cardCornerRadius="12dp" app:cardElevation="6dp" app:contentPadding="2dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="4dp">
                    <!--  Заголовок карточки  -->
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="ИГРОВЫЕ КОМНАТЫ" android:textSize="14sp" android:textColor="#B22222" android:textStyle="bold" android:padding="12dp" android:background="#0F0F0F" android:fontFamily="sans-serif-condensed"/>
                    <!--  Список комнат  -->
                    <androidx.recyclerview.widget.RecyclerView android:id="@+id/roomsRecyclerView" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp" android:clipToPadding="false" android:overScrollMode="never" app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" tools:listitem="@layout/item_room"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <!--  Нет комнат сообщение  -->
            <TextView android:id="@+id/noRoomsText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🎴 Нет активных столов\nСоздайте первый и начните игру!" android:textSize="16sp" android:textColor="#C0C0C0" android:gravity="center" android:layout_gravity="center" android:layout_marginTop="40dp" android:padding="20dp" android:background="#1A1A1A" android:visibility="gone" android:fontFamily="sans-serif-light" app:cardCornerRadius="8dp"/>
        </LinearLayout>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
    <!--  Нижняя панель с кнопками  -->
    <LinearLayout android:id="@+id/bottomPanel" android:layout_width="0dp" android:layout_height="wrap_content" android:orientation="horizontal" android:background="@color/black" android:padding="16dp" android:elevation="12dp" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent">
        <!--  Кнопка создания комнаты  -->
        <com.google.android.material.button.MaterialButton android:id="@+id/createRoomButton" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:text="СОЗДАТЬ КОМНАТУ" android:textSize="14sp" android:textColor="#FFFFFF" android:textAllCaps="true" android:letterSpacing="0.1" app:backgroundTint="#8B0000" app:cornerRadius="0dp" android:layout_marginEnd="8dp" android:fontFamily="sans-serif-medium" app:iconTint="#FFFFFF" app:iconPadding="8dp" app:iconGravity="textStart"/>
        <!--  Кнопка присоединения  -->
        <com.google.android.material.button.MaterialButton android:id="@+id/joinRoomButton" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:text="ПРИСОЕДИНИТЬСЯ" android:textSize="14sp" android:textColor="#FFFFFF" android:textAllCaps="true" android:letterSpacing="0.1" app:backgroundTint="#2D2D2D" app:cornerRadius="0dp" android:layout_marginStart="8dp" android:fontFamily="sans-serif-medium" app:iconTint="#FFFFFF" app:iconPadding="8dp" app:iconGravity="textStart"/>
    </LinearLayout>
    <!--  Прогресс бар  -->
    <ProgressBar android:id="@+id/progressBar" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" android:indeterminateTint="#8B0000" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>