<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/bubbleContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingHorizontal="8dp"
    android:paddingVertical="3dp">

    <!-- Аватар (только для чужих сообщений) -->
    <ImageView
        android:id="@+id/chatAvatar"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_player_avatar1"
        android:scaleType="centerCrop"
        android:background="@drawable/circle_avatar_background"
        android:layout_marginEnd="6dp"
        android:layout_gravity="bottom"
        android:visibility="gone"/>

    <!-- Пузырь с именем + текстом + временем -->
    <LinearLayout
        android:id="@+id/bubble"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxWidth="240dp"
        android:orientation="vertical"
        android:padding="8dp">

        <TextView
            android:id="@+id/chatName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="#8B0000"
            android:textStyle="bold"
            android:layout_marginBottom="2dp"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/chatMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.2"/>

        <TextView
            android:id="@+id/chatTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textColor="#777777"
            android:layout_gravity="end"
            android:layout_marginTop="2dp"/>

    </LinearLayout>

</LinearLayout>