<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <View
        android:id="@+id/fogOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0"
        android:background="#CC000000" />
    <!--  Казнь  -->
    <LinearLayout
        android:id="@+id/executionLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="invisible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:letterSpacing="0.2"
            android:text="ГОРОД ВЫНЕС ПРИГОВОР"
            android:textColor="#555555"
            android:textSize="14sp" />
        <!--  Карточка казнённого с крестом  -->
        <FrameLayout
            android:layout_width="200dp"
            android:layout_height="260dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/player_card_border"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="12dp">

                <ImageView
                    android:id="@+id/executedPlayerPhoto"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/circle_avatar_background"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_player_avatar1" />

                <TextView
                    android:id="@+id/executedNameText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:gravity="center"
                    android:text=""
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/executedRoleText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text=""
                    android:textColor="#BB86FC"
                    android:textSize="15sp"
                    android:visibility="gone" />
            </LinearLayout>
            <!--  Красный крест поверх карточки  -->
            <View
                android:id="@+id/crossHorizontal"
                android:layout_width="0dp"
                android:layout_height="6dp"
                android:layout_gravity="center"
                android:alpha="0"
                android:background="#CC0000"
                android:rotation="-45" />

            <View
                android:id="@+id/crossVertical"
                android:layout_width="6dp"
                android:layout_height="0dp"
                android:layout_gravity="center"
                android:alpha="0"
                android:background="#CC0000"
                android:rotation="-45" />
        </FrameLayout>
        <!--  Счётчик голосов  -->
        <TextView
            android:id="@+id/voteCountText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:gravity="center"
            android:text=""
            android:textColor="#555555"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/executedSubtext"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="казнён городом"
            android:textColor="#444444"
            android:textSize="14sp"
            android:visibility="gone" />
    </LinearLayout>
    <!--  Ничья / никого не казнили  -->
    <LinearLayout
        android:id="@+id/tieLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="🤝"
            android:textSize="80sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:gravity="center"
            android:letterSpacing="0.08"
            android:text="ГОРОД НЕ ДОГОВОРИЛСЯ"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tieSubtitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4"
            android:text="Голоса разделились.\nНаступает следующая ночь."
            android:textColor="#555555"
            android:textSize="16sp" />
    </LinearLayout>
    <!--  Таймер и кнопка  -->
    <LinearLayout
        android:id="@+id/continueLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/continueTimerText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text=""
            android:textColor="#444444"
            android:textSize="14sp" />

        <Button
            android:id="@+id/continueButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:backgroundTint="#1E1E1E"
            android:letterSpacing="0.15"
            android:paddingHorizontal="40dp"
            android:text="ПРОДОЛЖИТЬ"
            android:textColor="#666666"
            android:textSize="14sp"
            android:visibility="gone" />
    </LinearLayout>
</FrameLayout>