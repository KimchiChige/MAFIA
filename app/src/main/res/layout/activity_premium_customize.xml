<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <!-- Шапка -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/black"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:elevation="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/backButton"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_close"
            android:layout_marginEnd="16dp"
            android:padding="4dp"
            app:tint="#FFFFFF"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="КАСТОМИЗАЦИЯ"
            android:textSize="16sp"
            android:textColor="#FFD700"
            android:textStyle="bold"
            android:letterSpacing="0.1"/>

        <Button
            android:id="@+id/saveCustomizeButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="СОХРАНИТЬ"
            android:textSize="12sp"
            android:textColor="#000000"
            android:backgroundTint="#FFD700"
            android:paddingHorizontal="12dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- ═══════════ ПРЕДПРОСМОТР ═══════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ПРЕДПРОСМОТР"
                android:textColor="#777777"
                android:textSize="12sp"
                android:letterSpacing="0.15"
                android:layout_marginBottom="10dp"/>

            <FrameLayout
                android:id="@+id/previewCard"
                android:layout_width="130dp"
                android:layout_height="160dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="28dp"
                android:background="#1A1A1A">

                <!-- Фоновое изображение (чёрно-белое, с регулируемой прозрачностью) -->
                <ImageView
                    android:id="@+id/previewBgImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone"/>

                <!-- Контент: аватар, ник — всё центрировано поверх фона -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">

                    <!-- Аватарка + бейдж (налезает наполовину, без чёрного квадрата) -->
                    <FrameLayout
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_marginTop="12dp"
                        android:clipChildren="false"
                        android:clipToPadding="false">

                        <ImageView
                            android:id="@+id/previewAvatar"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:src="@drawable/ic_player_avatar1"
                            android:background="@drawable/circle_avatar_background"
                            android:scaleType="centerCrop"
                            android:layout_gravity="center"/>

                        <TextView
                            android:id="@+id/previewBadge"
                            android:layout_width="26dp"
                            android:layout_height="36dp"
                            android:text="👑"
                            android:textSize="12sp"
                            android:gravity="center"
                            android:layout_gravity="top|end"
                            android:layout_marginTop="-8dp"
                            android:layout_marginEnd="5dp"
                            />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/previewNickname"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ваш ник"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="12dp"/>
                </LinearLayout>

                <!-- Рамка карточки поверх всего -->
                <View
                    android:id="@+id/previewBorderOverlay"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>
            </FrameLayout>

            <!-- ═══════════ ЗНАЧОК НА АВАТАРКЕ ═══════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ЗНАЧОК НА АВАТАРКЕ"
                android:textColor="#777777"
                android:textSize="12sp"
                android:letterSpacing="0.15"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Нажмите на поле и выберите любой эмодзи с клавиатуры 👇"
                android:textColor="#888888"
                android:textSize="12sp"
                android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="28dp">

                <EditText
                    android:id="@+id/badgeEmojiInput"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:gravity="center"
                    android:textSize="36sp"
                    android:inputType="text"
                    android:maxLength="10"
                    android:background="#1A1A1A"
                    android:textColor="#FFFFFF"
                    android:cursorVisible="false"
                    android:hint="👑"
                    android:singleLine="true"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="Тапните на поле — откроется клавиатура. Переключитесь на эмодзи (😊) и выберите любой символ."
                    android:textColor="#666666"
                    android:textSize="12sp"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1A1A1A" android:layout_marginBottom="24dp"/>

            <!-- ═══════════ ЦВЕТ РАМКИ — КРУГЛАЯ ПАЛИТРА ═══════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ЦВЕТ РАМКИ КАРТОЧКИ"
                android:textColor="#777777"
                android:textSize="12sp"
                android:letterSpacing="0.15"
                android:layout_marginBottom="12dp"/>

            <com.example.mafia.ColorWheelView
                android:id="@+id/borderColorWheel"
                android:layout_width="220dp"
                android:layout_height="260dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="28dp"/>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1A1A1A" android:layout_marginBottom="24dp"/>

            <!-- ═══════════ ЦВЕТ НИКНЕЙМА — КРУГЛАЯ ПАЛИТРА ═══════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ЦВЕТ НИКНЕЙМА"
                android:textColor="#777777"
                android:textSize="12sp"
                android:letterSpacing="0.15"
                android:layout_marginBottom="12dp"/>

            <com.example.mafia.ColorWheelView
                android:id="@+id/nickColorWheel"
                android:layout_width="220dp"
                android:layout_height="260dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="28dp"/>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1A1A1A" android:layout_marginBottom="24dp"/>

            <!-- ═══════════ ФОН КАРТОЧКИ ═══════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ФОН КАРТОЧКИ"
                android:textColor="#777777"
                android:textSize="12sp"
                android:letterSpacing="0.15"
                android:layout_marginBottom="12dp"/>

            <!-- Переключатель режима -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <Button
                    android:id="@+id/btnBgModeColor"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="🎨 Цвет"
                    android:textSize="13sp"
                    android:backgroundTint="#1A1A1A"
                    android:textColor="#FFFFFF"/>

                <Button
                    android:id="@+id/btnBgModeImage"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="🖼 Фото"
                    android:textSize="13sp"
                    android:backgroundTint="#1A1A1A"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>

            <!-- Секция: цвет фона — тоже круглая палитра -->
            <LinearLayout
                android:id="@+id/bgColorSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <com.example.mafia.ColorWheelView
                    android:id="@+id/bgColorWheel"
                    android:layout_width="220dp"
                    android:layout_height="260dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="16dp"/>
            </LinearLayout>

            <!-- Секция: фото фона -->
            <LinearLayout
                android:id="@+id/bgImageSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <Button
                    android:id="@+id/pickBgImageButton"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="16dp"
                    android:text="📁 Выбрать фото из галереи"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#1A237E"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Фото автоматически станет чёрно-белым"
                    android:textColor="#666666"
                    android:textSize="11sp"
                    android:layout_marginBottom="12dp"/>

                <!-- Ползунок прозрачности фото -->
                <TextView
                    android:id="@+id/bgOpacityLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Непрозрачность: 60%"
                    android:textColor="#AAAAAA"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp"/>

                <SeekBar
                    android:id="@+id/bgOpacitySeek"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100"
                    android:progress="60"
                    android:progressTint="#FFD700"
                    android:thumbTint="#FFD700"/>
            </LinearLayout>

            <!-- Сбросить фон -->
            <Button
                android:id="@+id/clearBgButton"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="32dp"
                android:text="↩ Сбросить фон"
                android:textSize="12sp"
                android:textColor="#888888"
                android:backgroundTint="#111111"/>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>