<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="4dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/playerCard"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        app:cardBackgroundColor="@color/black"
        app:cardCornerRadius="10dp"
        app:cardElevation="2dp"
        android:foreground="@drawable/player_card_border">

        <!--
            FrameLayout строго на весь размер CardView.
            Фото-фон растянут точно по границам карточки, не смещая контент.
        -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Фоновое изображение карточки (Premium, чёрно-белое, с прозрачностью) -->
            <ImageView
                android:id="@+id/playerCardBgImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:visibility="gone"/>

            <!-- Основное содержимое карточки -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="6dp">

                <FrameLayout
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <ImageView
                        android:id="@+id/playerAvatar"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:src="@drawable/ic_player_avatar1"
                        android:background="@drawable/circle_avatar_background"
                        android:scaleType="centerCrop"
                        android:padding="0dp" />

                    <!-- Premium бейдж / звезда хоста: без подложки, налезает на фото -->
                    <TextView
                        android:id="@+id/playerBadgeText"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="-12dp"
                        android:layout_marginEnd="8dp"
                        android:gravity="center"
                        android:textSize="10sp"
                        android:visibility="gone" />
                </FrameLayout>

                <TextView
                    android:id="@+id/playerNameText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/playerRoleText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:textSize="11sp"
                    android:textColor="@color/light_text"
                    android:gravity="center"
                    android:maxLines="2"
                    android:visibility="gone" />

            </LinearLayout>
        </FrameLayout>

        <!-- Красный крест для мёртвых игроков (без анимации) -->
        <FrameLayout
            android:id="@+id/deadOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <!-- Полупрозрачный тёмно-красный фон -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#AA330000" />

            <!-- Крест: горизонтальная линия -->
            <View
                android:id="@+id/crossLineH"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_gravity="center"
                android:rotation="45"
                android:background="#FFCC0000" />

            <!-- Крест: вертикальная линия -->
            <View
                android:id="@+id/crossLineV"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_gravity="center"
                android:rotation="-45"
                android:background="#FFCC0000" />

        </FrameLayout>

    </androidx.cardview.widget.CardView>
</LinearLayout>