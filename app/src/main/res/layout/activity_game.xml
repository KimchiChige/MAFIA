<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/bg_gradient">
    <!--  ── Экран показа роли (появляется первым) ───────────────  -->
    <LinearLayout
        android:id="@+id/roleRevealLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/black"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="visible">

        <ImageView
            android:id="@+id/roleRevealImage"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:scaleType="centerCrop"
            android:visibility="gone" />

        <TextView
            android:id="@+id/roleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text=""
            android:textColor="@android:color/white"
            android:textSize="36sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </LinearLayout>
    <!--  ── Основной игровой интерфейс ──────────────────────────  -->
    <LinearLayout
        android:id="@+id/gameControlsLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone">
        <!--  Верхняя панель  -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_rounded"
            android:orientation="vertical"
            android:padding="16dp">
            <!--  Роль с каплями крови  -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/roleDisplayImage"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="8dp"
                        android:scaleType="centerCrop"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/roleDisplayText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@android:color/white"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <com.example.mafia.BloodDripView
                    android:id="@+id/bloodDripRole"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:layout_gravity="bottom" />
            </FrameLayout>
            <!--  Фаза с каплями крови (ночная фаза)  -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/phaseText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/light_text"
                    android:textSize="18sp" />

                <com.example.mafia.BloodDripView
                    android:id="@+id/bloodDripPhase"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_gravity="bottom"
                    android:visibility="gone" />
            </FrameLayout>

            <TextView
                android:id="@+id/timerText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text=""
                android:textColor="@color/light_text"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/infoText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text=""
                android:textColor="@color/light_text"
                android:textSize="14sp" />
        </LinearLayout>
        <!--  Экран ожидания ночью  -->
        <LinearLayout
            android:id="@+id/nightWaitingLayout"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/nightWaitingText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text=""
                android:textColor="@android:color/white"
                android:textSize="24sp"
                android:textStyle="bold" />

            <ProgressBar
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp" />
        </LinearLayout>
        <!--  Список игроков  -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/playersRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:visibility="gone" />
        <!--  Панель плюшек (показывается только живым игрокам)  -->
        <LinearLayout
            android:id="@+id/perksPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/perkShieldButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:background="@drawable/btn_mafia_final"
                android:backgroundTint="#1B3A2D"
                android:enabled="false"
                android:text="🛡️ x0"
                app:backgroundTint="@null"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/perkSelfhealButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginHorizontal="4dp"
                android:layout_weight="1"
                android:background="@drawable/btn_mafia_final"
                android:backgroundTint="#1B2B3A"
                android:enabled="false"
                app:backgroundTint="@null"
                android:text="💊 x0"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/perkInvisibleButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:background="@drawable/btn_mafia_final"
                android:backgroundTint="#2D1B3A"
                android:enabled="false"
                app:backgroundTint="@null"
                android:text="👁️ x0"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />
        </LinearLayout>
        <!--  Кнопка: начать голосование (только хост, только днём)  -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/startVotingButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/btn_mafia_final"
            android:backgroundTint="#1A237E"
            android:letterSpacing="0.08"
            app:backgroundTint="@null"
            android:text="🗳️ НАЧАТЬ ГОЛОСОВАНИЕ"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:visibility="gone" />
        <!--  Кнопка: подтвердить действие (ночь / голосование)  -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/actionButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/btn_mafia_final"
            android:backgroundTint="@android:color/holo_orange_dark"
            android:enabled="false"
            app:backgroundTint="@null"
            android:text="ПОДТВЕРДИТЬ"
            android:textColor="@android:color/white" />
        <!--  Premium: кнопка реанимации (видна только мёртвому Premium-игроку, 1 раз за игру)  -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/resurrectButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/btn_mafia_final"
            android:backgroundTint="#4A0080"
            android:letterSpacing="0.06"
            app:backgroundTint="@null"
            android:text="Реанимировать (1 раз за игру)"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:visibility="gone" />
    </LinearLayout>
    <!--  Глобальный прогресс  -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />
    <!--  ЧАТ — видим только в фазе дневного обсуждения  -->
    <LinearLayout
        android:id="@+id/chatPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:orientation="vertical"
        android:visibility="gone">
        <!--  Шапка чата  -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#8B0000"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="sans-serif-condensed"
                android:letterSpacing="0.1"
                android:text="💬 ОБСУЖДЕНИЕ"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/chatCloseButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:text="✕"
                android:textColor="#FFFFFF"
                android:textSize="18sp" />
        </LinearLayout>
        <!--  Список сообщений  -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/chatRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:padding="4dp" />
        <!--  Поле ввода  -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1A0A0A"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="8dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/chatInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_chat_input"
                android:hint="Сообщение..."
                android:inputType="textMultiLine"
                android:maxLines="3"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#555555"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButton xmlns:app="http://schemas.android.com/apk/res-auto"
                android:id="@+id/chatSendButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:padding="0dp"
                android:text="➤"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                app:backgroundTint="#8B0000"
                app:cornerRadius="24dp" />
        </LinearLayout>
    </LinearLayout>
    <!--  Кнопка открыть чат (плавающая, видна только в фазе дня)  -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton xmlns:app="http://schemas.android.com/apk/res-auto"
        android:id="@+id/openChatButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:contentDescription="Открыть чат"
        android:src="@android:drawable/ic_dialog_email"
        android:visibility="gone"
        app:backgroundTint="#8B0000"
        app:tint="#FFFFFF" />
</FrameLayout>