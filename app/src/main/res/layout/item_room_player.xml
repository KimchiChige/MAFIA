<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="6dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/playerCard"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        app:cardBackgroundColor="@color/black"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        android:foreground="@drawable/player_card_border">

        <!--
            FrameLayout строго на весь размер CardView.
            Фото-фон (playerCardBgImage) — первый слой, растянут точно
            по границам карточки (match_parent + centerCrop), поэтому
            не может "съехать" или не покрыть часть карточки.
        -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Фоновое изображение карточки (Premium, чёрно-белое, с прозрачностью) -->
            <ImageView
                android:id="@+id/playerCardBgImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:visibility="gone"/>

            <!-- Контент карточки — центрирован поверх фона -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp">

                <!-- Аватарка + бейдж/звезда (налезают наполовину на фото) -->
                <FrameLayout
                    android:layout_width="86dp"
                    android:layout_height="106dp"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <!-- Аватарка -->
                    <ImageView
                        android:id="@+id/playerAvatar"
                        android:layout_width="86dp"
                        android:layout_height="86dp"
                        android:src="@drawable/ic_player_avatar1"
                        android:background="@drawable/circle_avatar_background"
                        android:scaleType="centerCrop"
                        android:padding="0dp"/>

                    <!-- Звезда хоста: без подложки, крупнее, налезает на фото -->
                    <ImageView
                        android:id="@+id/hostStar"
                        android:layout_width="25dp"
                        android:layout_height="35dp"
                        android:src="@drawable/host_star"
                        android:visibility="gone"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="-10dp"
                        android:layout_marginEnd="10dp"/>

                    <!-- Premium бейдж: без фона, крупнее, налезает на фото -->
                    <TextView
                        android:id="@+id/premiumBadgeText"
                        android:layout_width="28dp"
                        android:layout_height="35dp"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="-10dp"
                        android:layout_marginEnd="10dp"
                        android:gravity="center"
                        android:textSize="12sp"
                        android:visibility="gone"/>

                </FrameLayout>

                <!-- Имя игрока -->
                <TextView
                    android:id="@+id/playerNameText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:layout_marginTop="10dp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:gravity="center"/>

                <!-- Иконки готовности -->
                <FrameLayout
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_marginTop="6dp">

                    <ImageView
                        android:id="@+id/notReadyIcon"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_close"
                        app:tint="#404040"
                        android:visibility="visible"
                        android:layout_gravity="center"/>

                    <ImageView
                        android:id="@+id/readyIcon"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_check_circle"
                        app:tint="#660000"
                        android:visibility="gone"
                        android:layout_gravity="center"/>

                </FrameLayout>

            </LinearLayout>
        </FrameLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>