<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="6dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="200dp"
        app:cardBackgroundColor="@color/black"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        android:foreground="@drawable/player_card_border"
        android:id="@+id/playerCard">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp">

            <!-- Контейнер для аватарки со звездой -->
            <!-- Контейнер для аватарки со звездой -->
            <FrameLayout
                android:layout_width="86dp"
                android:layout_height="86dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <!-- Круглая аватарка -->
                <ImageView
                    android:id="@+id/playerAvatar"
                    android:layout_width="86dp"
                    android:layout_height="86dp"
                    android:src="@drawable/ic_player_avatar1"
                    android:background="@drawable/circle_avatar_background"
                    android:scaleType="centerCrop"
                    android:padding="0dp"/>

                <!-- Звезда хоста (сдвинута левее, чтобы не обрезалась) -->
                <ImageView
                    android:id="@+id/hostStar"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/host_star"
                    android:visibility="gone"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="-4dp"
                    android:layout_marginEnd="-2dp"/>  <!-- Уменьшено с 8dp до -2dp -->
            </FrameLayout>

            <!-- Имя игрока -->
            <TextView
                android:id="@+id/playerNameText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:layout_marginTop="6dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:gravity="center"/>

            <!-- Контейнер для статуса -->
            <FrameLayout
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginTop="6dp">

                <ImageView
                    android:id="@+id/notReadyIcon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_close"
                    app:tint="#404040"
                    android:visibility="visible"
                    android:layout_gravity="center"/>

                <ImageView
                    android:id="@+id/readyIcon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_check_circle"
                    app:tint="#660000"
                    android:visibility="gone"
                    android:layout_gravity="center"/>

            </FrameLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>