<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/bg_dialog_mafia"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/mafiaDialogTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-condensed"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        tools:text="🛡️ Активировать Щит?" />

    <View
        android:id="@+id/mafiaDialogDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="14dp"
        android:background="#5A0000" />

    <TextView
        android:id="@+id/mafiaDialogMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:lineSpacingExtra="3dp"
        android:textColor="#B0B0B0"
        android:textSize="15sp"
        tools:text="Текст сообщения" />

    <FrameLayout
        android:id="@+id/mafiaDialogContentSlot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:gravity="end"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/mafiaDialogNegative"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_dialog_btn_negative"
            android:minWidth="96dp"
            android:paddingHorizontal="18dp"
            android:textAllCaps="true"
            android:textColor="#D0D0D0"
            android:textSize="13sp"
            app:backgroundTint="@null"
            android:textStyle="bold"
            tools:text="ОТМЕНА" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/mafiaDialogPositive"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:background="@drawable/bg_dialog_btn_positive"
            android:minWidth="96dp"
            android:paddingHorizontal="18dp"
            android:textAllCaps="true"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            app:backgroundTint="@null"
            tools:text="ОК" />
    </LinearLayout>
</LinearLayout>