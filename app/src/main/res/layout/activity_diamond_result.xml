<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp">
        <!--  Заголовок  -->
        <TextView
            android:id="@+id/drTitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:gravity="center"
            android:letterSpacing="0.1"
            android:text="ИГРА ОКОНЧЕНА"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/drSubtitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:gravity="center"
            android:text=""
            android:textColor="#666666"
            android:textSize="15sp" />
        <!--  Большой алмаз + счётчик заработанного  -->
        <TextView
            android:id="@+id/drDiamondEmoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="💎"
            android:textSize="72sp" />

        <TextView
            android:id="@+id/drDiamondCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:gravity="center"
            android:text="+0"
            android:textColor="#FFD700"
            android:textSize="56sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:gravity="center"
            android:text="алмазов заработано"
            android:textColor="#555555"
            android:textSize="14sp" />

        <!--  Premium бонус (+30)  -->
        <TextView
            android:id="@+id/drPremiumBonus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp"
            android:background="#332B1A00"
            android:gravity="center"
            android:paddingHorizontal="14dp"
            android:paddingVertical="6dp"
            android:text="👑 Premium бонус: +30 💎"
            android:textColor="#FFD700"
            android:textSize="14sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <!--  Разделитель  -->
        <View
            android:layout_width="120dp"
            android:layout_height="1dp"
            android:layout_marginBottom="24dp"
            android:background="#1A1A1A" />
        <!--  Итоговый баланс  -->
        <TextView
            android:id="@+id/drTotalLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="Ваш баланс"
            android:textColor="#444444"
            android:textSize="13sp"
            android:visibility="invisible" />

        <TextView
            android:id="@+id/drTotalCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="56dp"
            android:text=""
            android:textColor="#AAAAAA"
            android:textSize="22sp"
            android:textStyle="bold"
            android:visibility="invisible" />
        <!--  Кнопка в лобби  -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/drLobbyButton"
            android:layout_width="220dp"
            android:layout_height="52dp"
            android:background="@drawable/btn_mafia_final"
            android:backgroundTint="@null"
            android:letterSpacing="0.15"
            android:text="В ЛОББИ"
            android:textColor="#CCCCCC"
            android:textSize="15sp"
            app:backgroundTint="@null" />
    </LinearLayout>
</FrameLayout>