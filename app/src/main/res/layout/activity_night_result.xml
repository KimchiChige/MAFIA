<!--  ЗАМЕНЯЕТ activity_night_result.xml  -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#0A0A0A">
    <!--  Фоновый туман  -->
    <View android:id="@+id/fogOverlay" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#CC000000" android:alpha="0"/>
    <!--  СМЕРТЬ: карточка игрока с анимированным красным крестом  -->
    <LinearLayout android:id="@+id/deathLayout" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:padding="32dp" android:visibility="invisible">
        <!--  Заголовок  -->
        <TextView android:id="@+id/headlineText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ЭТУ НОЧЬ\nПЕРЕЖИЛИ НЕ ВСЕ" android:textSize="20sp" android:textStyle="bold" android:textColor="#888888" android:gravity="center" android:letterSpacing="0.15" android:layout_marginBottom="28dp"/>
        <!--  Карточка погибшего  -->
        <FrameLayout android:layout_width="200dp" android:layout_height="260dp" android:layout_marginBottom="20dp">
            <!--  Фон карточки  -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:background="@drawable/player_card_border" android:gravity="center" android:padding="12dp">
                <!--  Фото игрока  -->
                <ImageView android:id="@+id/killedPlayerPhoto" android:layout_width="100dp" android:layout_height="100dp" android:src="@drawable/ic_player_avatar1" android:scaleType="centerCrop" android:background="@drawable/circle_avatar_background" android:layout_marginBottom="12dp"/>
                <!--  Имя  -->
                <TextView android:id="@+id/killedNameText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="" android:textSize="18sp" android:textStyle="bold" android:textColor="#FFFFFF" android:gravity="center" android:layout_marginBottom="8dp"/>
                <!--  Роль  -->
                <TextView android:id="@+id/killedRoleText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="" android:textSize="15sp" android:textColor="#BB86FC" android:gravity="center" android:visibility="gone"/>
            </LinearLayout>
            <!--  Красный крест анимируется поверх карточки  -->
            <!--  Горизонтальная линия  -->
            <View android:id="@+id/crossHorizontal" android:layout_width="0dp" android:layout_height="6dp" android:background="#CC0000" android:layout_gravity="center" android:alpha="0" android:rotation="-45"/>
            <!--  Вертикальная линия  -->
            <View android:id="@+id/crossVertical" android:layout_width="6dp" android:layout_height="0dp" android:background="#CC0000" android:layout_gravity="center" android:alpha="0" android:rotation="-45"/>
        </FrameLayout>
        <!--  Подпись  -->
        <TextView android:id="@+id/killedSubtitleText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="был среди нас" android:textSize="14sp" android:textColor="#555555" android:gravity="center" android:visibility="gone"/>
    </LinearLayout>
    <!--  СПАСЁН / НИКТО НЕ УМЕР  -->
    <LinearLayout android:id="@+id/savedLayout" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:padding="32dp" android:visibility="gone">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="✨" android:textSize="80sp" android:layout_marginBottom="24dp"/>
        <TextView android:id="@+id/savedTitleText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ЭТОЙ НОЧЬЮ\nВСЕ ОСТАЛИСЬ ЖИВЫ" android:textSize="26sp" android:textStyle="bold" android:textColor="#FFFFFF" android:gravity="center" android:letterSpacing="0.1" android:layout_marginBottom="16dp"/>
        <TextView android:id="@+id/savedSubtitleText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="" android:textSize="16sp" android:textColor="#888888" android:gravity="center"/>
    </LinearLayout>
    <!--  Результат шерифа  -->
    <LinearLayout android:id="@+id/sheriffResultLayout" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_gravity="bottom" android:orientation="vertical" android:background="#1A1A2E" android:padding="20dp" android:layout_margin="16dp" android:visibility="gone">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🕵️ ТОЛЬКО ДЛЯ ВАШИХ ГЛАЗ" android:textSize="12sp" android:textColor="#555555" android:letterSpacing="0.2" android:layout_marginBottom="8dp"/>
        <TextView android:id="@+id/sheriffResultText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="" android:textSize="18sp" android:textStyle="bold" android:textColor="#FFFFFF"/>
    </LinearLayout>
    <!--  Таймер / кнопка продолжить  -->
    <LinearLayout android:id="@+id/continueLayout" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_gravity="bottom|center_horizontal" android:orientation="vertical" android:gravity="center" android:padding="24dp" android:visibility="gone">
        <TextView android:id="@+id/continueTimerText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="" android:textSize="14sp" android:textColor="#444444" android:layout_marginBottom="12dp"/>
        <Button android:id="@+id/continueButton" android:layout_width="wrap_content" android:layout_height="48dp" android:paddingHorizontal="40dp" android:text="ПРОДОЛЖИТЬ" android:textSize="14sp" android:letterSpacing="0.15" android:backgroundTint="#1E1E1E" android:textColor="#666666" android:visibility="gone"/>
    </LinearLayout>
</FrameLayout>