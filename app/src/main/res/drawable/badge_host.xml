<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Оранжевая заливка -->
    <solid android:color="#FF9800"/>

    <!-- Скругленные углы (делает бейдж овальным/круглым) -->
    <corners android:radius="16dp"/>

    <!-- Тонкая белая обводка по краям (опционально) -->
    <stroke
        android:width="1dp"
        android:color="#FFFFFF"/>

    <!-- Внутренние отступы для текста -->
    <padding
        android:left="8dp"
        android:right="8dp"
        android:top="4dp"
        android:bottom="4dp"/>
</shape>