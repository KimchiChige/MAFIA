<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Нажатое состояние -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <!-- Черный фон -->
            <solid android:color="#000000"/>

            <!-- Красная обводка (чуть темнее для нажатия) -->
            <stroke
                android:width="2dp"
                android:color="#8B0000"/>

            <!-- Скругление только снизу -->
            <corners
                android:topLeftRadius="0dp"
                android:topRightRadius="0dp"
                android:bottomLeftRadius="20dp"
                android:bottomRightRadius="20dp"/>

            <!-- Отступы внутри кнопки -->
            <padding
                android:left="4dp"
                android:top="4dp"
                android:right="4dp"
                android:bottom="6dp"/>
        </shape>
    </item>

    <!-- Обычное состояние -->
    <item>
        <shape android:shape="rectangle">
            <!-- Черный фон -->
            <solid android:color="#000000"/>

            <!-- Красная обводка -->
            <stroke
                android:width="2dp"
                android:color="#660000"/>

            <!-- Скругление только снизу -->
            <corners
                android:topLeftRadius="0dp"
                android:topRightRadius="0dp"
                android:bottomLeftRadius="20dp"
                android:bottomRightRadius="20dp"/>

            <!-- Отступы внутри кнопки -->
            <padding
                android:left="4dp"
                android:top="4dp"
                android:right="4dp"
                android:bottom="6dp"/>
        </shape>
    </item>

</selector>