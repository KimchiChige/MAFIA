<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.MAFIA" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="Theme.MAFIA" parent="Base.Theme.MAFIA" />

    <!-- Единый стиль для ВСЕХ диалогов MAFIA.
         Прозрачный фон окна — реальный фон задаёт bg_dialog_mafia.xml в layout-е.
         windowMinWidthMinor ограничивает ширину диалога на планшетах. -->
    <style name="MafiaDialog" parent="Theme.MaterialComponents.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowMinWidthMinor">85%</item>
        <item name="android:windowNoTitle">true</item>
        <item name="colorPrimary">#8B0000</item>
        <item name="colorAccent">#8B0000</item>
        <item name="android:textColorPrimary">#FFFFFF</item>
    </style>

</resources>